# Shopify Partner Dashboard API Key
SHOPIFY_API_KEY=

# Shopify Partner Dashboard API Secret
SHOPIFY_API_SECRET=

# The ngrok or production URL of this app
SHOPIFY_APP_URL=

# OAuth scopes requested from Shopify
SCOPES=write_discounts,read_orders,read_products

# OpenAI API key for the negotiation AI
OPENAI_API_KEY=

# A long random string for session encryption
SESSION_SECRET=

# ── Supabase ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Supabase dashboard → Settings → Database → URI)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Supabase project URL (Supabase dashboard → Settings → API)
SUPABASE_URL=

# Supabase service role secret key — server-side only, never expose client-side
SUPABASE_SERVICE_ROLE_KEY=

# Supabase anon/public key — safe to use in the storefront widget
SUPABASE_ANON_KEY=
