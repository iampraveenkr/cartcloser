# Shopify Partner Dashboard API Key
SHOPIFY_API_KEY=

# Shopify Partner Dashboard API Secret
SHOPIFY_API_SECRET=

# The ngrok or production URL of this app
SHOPIFY_APP_URL=

# OAuth scopes requested from Shopify
SCOPES=write_discounts,read_orders,read_products

# OpenAI API key for the negotiation AI
OPENAI_API_KEY=

# A long random string for session encryption
SESSION_SECRET=

# ── Supabase ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string with Prisma connection pool (used at runtime)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.nwusukyjacdqdbrihvfo.supabase.co:5432/postgres?connection_limit=5&pool_timeout=2

# Direct PostgreSQL connection — no pool params (used by prisma migrate only)
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.nwusukyjacdqdbrihvfo.supabase.co:5432/postgres

# Supabase project URL
SUPABASE_URL=https://nwusukyjacdqdbrihvfo.supabase.co

